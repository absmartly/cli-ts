{
  "name": "@absmartly/cli",
  "version": "0.1.0",
  "description": "ABSmartly CLI - A/B Testing and Feature Flags command-line tool",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/absmartly/cli-ts.git"
  },
  "bugs": {
    "url": "https://github.com/absmartly/cli-ts/issues"
  },
  "homepage": "https://github.com/absmartly/cli-ts#readme",
  "bin": {
    "abs": "./dist/index.js",
    "absmartly-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "absmartly",
    "ab-testing",
    "feature-flags",
    "experimentation",
    "cli"
  ],
  "author": "ABsmartly",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "keytar": "^7.9.0",
    "open": "^10.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.19.0",
    "jsdom": "^28.0.0",
    "msw": "^2.12.8",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
